# ============================================================
# DMS — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
POSTGRES_USER=dms
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=dms
DATABASE_URL=postgresql+asyncpg://dms:change_me_in_production@postgres:5432/dms

# --- JWT ---
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_64_CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_ENV=development
APP_NAME=DMS
APP_VERSION=0.1.0
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Company (shown on invoice PDF and login page) ---
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=Dhaka, Bangladesh
COMPANY_PHONE=+8801XXXXXXXXX
COMPANY_VAT_BIN=XXXXXXXXXX-XXXX

# --- SMS (SSL Commerz — Sprint 7) ---
SMS_API_KEY=your_sslcommerz_sms_api_key
SMS_SENDER_ID=your_sender_id
SMS_BASE_URL=https://sms.sslwireless.com

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
